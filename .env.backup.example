# PostgreSQL Backup Configuration
# Copy this file to .env.backup and fill in your credentials
# chmod 600 .env.backup (bảo mật file)

# PostgreSQL Connection (from Docker Compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jft_database
DB_USER=postgres
DB_PASSWORD=your-secure-password-here

# Backup Settings
BACKUP_DIR=/var/backups/postgres
RETENTION_DAYS=14

# Docker Container Name (từ docker-compose.yml)
POSTGRES_CONTAINER=jft-postgres

# Optional: S3 Upload (nếu muốn backup offsite)
# AWS_BUCKET=your-s3-bucket
# AWS_REGION=us-east-1
